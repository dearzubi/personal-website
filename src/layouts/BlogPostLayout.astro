---
import type { CollectionEntry } from 'astro:content';
import Footer from '@/components/Footer.astro';
import Giscus from '@/components/Giscus.astro';
import Header from '@/components/Header.astro';
import SearchDialog from '@/components/SearchDialog.astro';
import { profile, siteUrl } from '@/data/site';
import { dayjs } from '@/lib/dayjs';
import BaseLayout from './BaseLayout.astro';

type Props = {
  post: CollectionEntry<'blog'>;
  readingTime: string;
};
const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage } = post.data;

const origin = Astro.site?.toString() ?? siteUrl;
const canonical = new URL(`/blog/${post.id}/`, origin).toString();
const heroImageAbsolute = heroImage ? new URL(heroImage.src, origin).toString() : undefined;
const publishedTime = pubDate.toISOString();
const modifiedTime = (updatedDate ?? pubDate).toISOString();

const baseProps = {
  title,
  description,
  ogType: 'article' as const,
  article: {
    publishedTime,
    ...(updatedDate && { modifiedTime }),
    tags,
  },
  ...(heroImage && { ogImage: heroImage.src }),
};

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: { '@type': 'Person', name: profile.name, url: origin },
  publisher: { '@type': 'Person', name: profile.name, url: origin },
  url: canonical,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  ...(heroImageAbsolute && { image: heroImageAbsolute }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
}).replace(/</g, '\\u003c');

const rawGiscusRepo = import.meta.env.PUBLIC_GISCUS_REPO ?? '';
const giscusRepo = /^[^/\s]+\/[^/\s]+$/.test(rawGiscusRepo)
  ? (rawGiscusRepo as `${string}/${string}`)
  : null;
const giscusRepoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const giscusCategory = import.meta.env.PUBLIC_GISCUS_CATEGORY;
const giscusCategoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;
const giscusReady =
  import.meta.env.PROD && giscusRepo && giscusRepoId && giscusCategory && giscusCategoryId;
---

<BaseLayout {...baseProps}>
  <script is:inline type="application/ld+json" slot="head" set:html={jsonLd} />
  {giscusReady && (
    <link rel="preconnect" href="https://giscus.app" crossorigin slot="head" />
  )}
  <Header />
  <main>
    <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-8">
      <h1 class="text-4xl font-bold md:text-5xl">{title}</h1>
      <p class="mt-3 text-sm text-muted-foreground">
        <time datetime={pubDate.toISOString()}>{dayjs(pubDate).format('MMM D, YYYY')}</time>
        {updatedDate && (
          <span> · Updated <time datetime={updatedDate.toISOString()}>{dayjs(updatedDate).format('MMM D, YYYY')}</time></span>
        )}
        {readingTime && <span> · {readingTime}</span>}
      </p>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a href={`/blog/tags/${encodeURIComponent(tag)}`} class="inline-flex rounded-full border border-border px-3 py-1 text-xs">#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none dark:prose-invert">
      <slot />
    </div>
    {post.data.series && (
      <aside class="mt-12 rounded-2xl border border-border p-6">
        <p class="text-sm text-muted-foreground">Part of series</p>
        <a href={`/blog/series/${post.data.series.id}`} class="font-semibold hover:text-primary">View all posts in this series →</a>
      </aside>
    )}
    {giscusReady && (
      <Giscus
        repo={giscusRepo}
        repoId={giscusRepoId}
        category={giscusCategory}
        categoryId={giscusCategoryId}
      />
    )}
    </article>
  </main>
  <Footer />
  <SearchDialog />
  <script>
    import mediumZoom from 'medium-zoom';
    import 'medium-zoom/dist/style.css';

    mediumZoom('.prose img', {
      margin: 24,
      background: 'var(--color-background)',
      scrollOffset: 100,
    });

    if (navigator.clipboard?.writeText) {
      const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
      const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;

      const blocks = document.querySelectorAll<HTMLPreElement>('.prose pre.astro-code');
      blocks.forEach((pre) => {
        if (pre.parentElement?.classList.contains('code-block')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'code-block';
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'copy-btn';
        button.setAttribute('aria-label', 'Copy code');
        button.innerHTML = copyIcon;
        wrapper.appendChild(button);

        let resetTimer: ReturnType<typeof setTimeout> | undefined;
        button.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(pre.innerText);
            button.dataset.copied = 'true';
            button.setAttribute('aria-label', 'Copied');
            button.innerHTML = checkIcon;
            if (resetTimer) clearTimeout(resetTimer);
            resetTimer = setTimeout(() => {
              delete button.dataset.copied;
              button.setAttribute('aria-label', 'Copy code');
              button.innerHTML = copyIcon;
            }, 1500);
          } catch {
            /* noop: clipboard write failed (e.g. permissions) */
          }
        });
      });
    }
  </script>
</BaseLayout>
