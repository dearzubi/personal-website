---
import type { CollectionEntry } from 'astro:content';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import { dayjs } from '@/lib/dayjs';
import BaseLayout from './BaseLayout.astro';

type Props = {
  post: CollectionEntry<'blog'>;
  readingTime: string;
};
const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
---

<BaseLayout title={title} description={description}>
  <Header />
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-8">
      <h1 class="text-4xl font-bold md:text-5xl">{title}</h1>
      <p class="mt-3 text-sm text-(--color-muted-foreground)">
        <time datetime={pubDate.toISOString()}>{dayjs(pubDate).format('MMM D, YYYY')}</time>
        {updatedDate && (
          <span> · Updated <time datetime={updatedDate.toISOString()}>{dayjs(updatedDate).format('MMM D, YYYY')}</time></span>
        )}
        <span> · {readingTime}</span>
      </p>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a href={`/blog/tags/${tag}`} class="inline-flex rounded-full border border-(--color-border) px-3 py-1 text-xs">#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none dark:prose-invert">
      <slot />
    </div>
    {post.data.series && (
      <aside class="mt-12 rounded-2xl border border-(--color-border) p-6">
        <p class="text-sm text-(--color-muted-foreground)">Part of series</p>
        <a href={`/blog/series/${post.data.series.id}`} class="font-semibold hover:text-(--color-primary)">View all posts in this series →</a>
      </aside>
    )}
  </article>
  <Footer />
</BaseLayout>
