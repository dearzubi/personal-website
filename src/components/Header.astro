---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isBlog = pathname.startsWith('/blog');

const sectionNav = [
  { href: '/#home', id: 'home', label: 'Home', icon: 'lucide:home' },
  { href: '/#skills', id: 'skills', label: 'Skills', icon: 'lucide:code-2' },
  { href: '/#experience', id: 'experience', label: 'Experience', icon: 'lucide:briefcase' },
  { href: '/#projects', id: 'projects', label: 'Projects', icon: 'lucide:folder-open' },
  { href: '/#education', id: 'education', label: 'Education', icon: 'lucide:graduation-cap' },
  { href: '/#contact', id: 'contact', label: 'Contact', icon: 'lucide:mail' },
];
---

<header
  class="fixed top-0 z-50 w-full bg-transparent transition-all duration-300"
  data-header
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href={isHome ? '/#home' : '/'} class="group flex items-center">
        <span
          class="bg-gradient-to-r from-sky-500 to-sky-600 bg-clip-text text-xl font-bold text-transparent"
        >
          Zubair Khalid
        </span>
      </a>

      <nav class="hidden items-center space-x-1 md:flex" aria-label="Primary">
        {
          sectionNav.map((item) => (
            <a
              href={item.href}
              data-section-link={item.id}
              class="group relative rounded-xl px-4 py-2 text-sm font-medium transition-all duration-300"
            >
              <span class="section-pill absolute inset-0 rounded-xl bg-sky-50 opacity-0 transition-opacity duration-300 group-hover:opacity-100 dark:bg-sky-900/50" />
              <span class="relative z-10 flex items-center gap-2">
                <Icon
                  name={item.icon}
                  class="section-icon size-4 text-gray-600 transition-colors group-hover:text-sky-600 dark:text-gray-300 dark:group-hover:text-sky-400"
                />
                <span class="section-label text-gray-600 transition-colors group-hover:text-sky-600 dark:text-gray-300 dark:group-hover:text-sky-400">
                  {item.label}
                </span>
              </span>
            </a>
          ))
        }
        <a
          href="/blog"
          data-blog-link
          class="group relative rounded-xl px-4 py-2 text-sm font-medium transition-all duration-300"
        >
          <span class="blog-pill absolute inset-0 rounded-xl bg-sky-50 opacity-0 transition-opacity duration-300 group-hover:opacity-100 dark:bg-sky-900/50" />
          <span class="relative z-10 flex items-center gap-2">
            <Icon
              name="lucide:book-open"
              class="blog-icon size-4 text-gray-600 transition-colors group-hover:text-sky-600 dark:text-gray-300 dark:group-hover:text-sky-400"
            />
            <span class="blog-label text-gray-600 transition-colors group-hover:text-sky-600 dark:text-gray-300 dark:group-hover:text-sky-400">
              Blog
            </span>
          </span>
        </a>
      </nav>

      <div class="flex items-center gap-2">
        {isBlog && (
          <button
            type="button"
            data-search-trigger
            aria-label="Search blog"
            class="hidden cursor-pointer items-center gap-2 rounded-lg border border-border bg-muted px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-gray-200 sm:flex dark:hover:bg-gray-700"
          >
            <Icon name="lucide:search" class="size-4" />
            <span>Search</span>
            <kbd
              class="ml-2 rounded border border-border bg-background px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground"
            >
              ⌘K
            </kbd>
          </button>
        )}
        {isBlog && (
          <button
            type="button"
            data-search-trigger
            aria-label="Search blog"
            class="flex cursor-pointer items-center rounded-lg border border-border p-2 text-foreground transition-colors hover:bg-muted sm:hidden"
          >
            <Icon name="lucide:search" class="size-4" />
          </button>
        )}
        <ThemeToggle />
        <button
          type="button"
          data-mobile-menu-toggle
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
          class="cursor-pointer rounded-lg border border-border p-2 text-foreground transition-colors hover:bg-muted md:hidden"
        >
          <Icon name="lucide:menu" data-mobile-menu-icon-open class="size-5" />
          <Icon name="lucide:x" data-mobile-menu-icon-close class="hidden size-5" />
        </button>
      </div>
    </div>

    <nav
      id="mobile-menu"
      aria-label="Mobile"
      data-mobile-menu
      class="hidden border-t border-gray-200 bg-white/95 pb-4 backdrop-blur-sm md:hidden dark:border-gray-700 dark:bg-gray-900/95"
    >
      <ul class="flex flex-col gap-1 pt-3">
        {
          sectionNav.map((item) => (
            <li>
              <a
                href={item.href}
                data-mobile-link
                class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-gray-700 transition-colors hover:bg-sky-50 hover:text-sky-600 dark:text-gray-200 dark:hover:bg-sky-900/40 dark:hover:text-sky-400"
              >
                <Icon name={item.icon} class="size-4" />
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/blog"
            data-mobile-link
            class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium text-gray-700 transition-colors hover:bg-sky-50 hover:text-sky-600 dark:text-gray-200 dark:hover:bg-sky-900/40 dark:hover:text-sky-400"
          >
            <Icon name="lucide:book-open" class="size-4" />
            Blog
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<div class="h-16" aria-hidden="true"></div>

<script is:inline define:vars={{ isHome }}>
  const activeClasses = {
    pill: 'opacity-100',
    inactivePill: 'opacity-0',
    text: ['text-sky-600', 'dark:text-sky-400'],
    inactiveText: ['text-gray-600', 'dark:text-gray-300'],
  };

  function setActive(link) {
    if (!link) return;
    const pill = link.querySelector('[class*="-pill"]');
    const icon = link.querySelector('[class*="-icon"]');
    const label = link.querySelector('[class*="-label"]');
    pill?.classList.remove('opacity-0');
    pill?.classList.add('opacity-100');
    for (const el of [icon, label]) {
      el?.classList.add(...activeClasses.text);
      el?.classList.remove(...activeClasses.inactiveText);
    }
  }

  function clearActive(link) {
    if (!link) return;
    const pill = link.querySelector('[class*="-pill"]');
    const icon = link.querySelector('[class*="-icon"]');
    const label = link.querySelector('[class*="-label"]');
    pill?.classList.remove('opacity-100');
    pill?.classList.add('opacity-0');
    for (const el of [icon, label]) {
      el?.classList.remove(...activeClasses.text);
      el?.classList.add(...activeClasses.inactiveText);
    }
  }

  function init() {
    const sectionLinks = Array.from(document.querySelectorAll('[data-section-link]'));
    const blogLink = document.querySelector('[data-blog-link]');

    if (isHome) {
      setActive(sectionLinks[0]);

      const sections = sectionLinks
        .map((link) => ({ link, section: document.getElementById(link.dataset.sectionLink) }))
        .filter((x) => x.section);

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!visible) return;
          const activeId = visible.target.id;
          for (const { link } of sections) {
            if (link.dataset.sectionLink === activeId) setActive(link);
            else clearActive(link);
          }
        },
        { rootMargin: '-40% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] },
      );
      for (const { section } of sections) observer.observe(section);
    } else {
      for (const link of sectionLinks) clearActive(link);
      if (document.location.pathname.startsWith('/blog')) setActive(blogLink);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  (function setupMobileMenu() {
    const toggle = document.querySelector('[data-mobile-menu-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');
    if (!toggle || !menu) return;

    const openIcon = toggle.querySelector('[data-mobile-menu-icon-open]');
    const closeIcon = toggle.querySelector('[data-mobile-menu-icon-close]');

    function setOpen(open) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.classList.toggle('hidden', !open);
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    menu.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  })();

  (function setupHeaderScroll() {
    const header = document.querySelector('[data-header]');
    if (!header) return;

    const scrolledLight = ['border-b', 'border-gray-200', 'bg-white/90', 'shadow-lg', 'backdrop-blur-sm'];
    const scrolledDark  = ['dark:border-gray-700', 'dark:bg-gray-900/90'];

    function applyScrollState() {
      if (window.scrollY > 50) {
        header.classList.add(...scrolledLight, ...scrolledDark);
      } else {
        header.classList.remove(...scrolledLight, ...scrolledDark);
      }
    }

    applyScrollState();
    window.addEventListener('scroll', applyScrollState, { passive: true });
  })();
</script>
