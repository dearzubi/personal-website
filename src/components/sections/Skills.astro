---
import { skills } from '@/data/site';
---

<section id="skills" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-bold md:text-4xl">Skills &amp; Technologies</h2>
  <p class="mt-4 text-lg text-(--color-muted-foreground)">
    A comprehensive overview of my technical expertise and the technologies I work with.
  </p>

  <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
    {Object.entries(skills).map(([category, items]) => (
      <div>
        <h3 class="text-lg font-semibold">
          {category}
          <span class="ml-2 inline-flex rounded-full bg-(--color-muted) px-2 py-0.5 text-xs text-(--color-muted-foreground)">
            {items.length}
          </span>
        </h3>
        <div class="mt-3 flex flex-wrap gap-2">
          {items.map((item) => (
            <span class="inline-flex rounded-lg border border-(--color-border) bg-(--color-muted) px-3 py-2 text-sm">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <p class="mt-16 text-center text-lg text-(--color-muted-foreground)">
    Always learning and exploring new technologies to stay current with industry trends.
  </p>
</section>
