---
import { Icon } from 'astro-icon/components';
import { skills } from '@/data/site';
import { getSkillIcon } from '@/lib/getSkillIcon';

const categories = Object.keys(skills) as Array<keyof typeof skills>;
const firstCategory = categories[0];

function slugify(value: string) {
  return value
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---

<section id="skills" class="py-24">
  <div class="section-container">
    <div class="mb-16 text-center">
      <h2 class="section-title">Skills &amp; Technologies</h2>
      <p class="section-subtitle mx-auto text-center">
        A comprehensive overview of my technical expertise and the technologies I work with.
      </p>
    </div>

    <div
      id="skills-tablist"
      role="tablist"
      aria-label="Skill categories"
      class="mb-12 flex flex-wrap justify-center gap-3"
    >
      {
        categories.map((category) => {
          const isActive = category === firstCategory;
          const slug = slugify(category);
          return (
            <button
              role="tab"
              id={`tab-${slug}`}
              aria-selected={isActive ? 'true' : 'false'}
              aria-controls={`panel-${slug}`}
              data-category={category}
              class:list={[
                'chip-tab cursor-pointer rounded-full px-6 py-3 text-sm font-medium transition-all duration-300',
                isActive
                  ? 'bg-sky-700 text-white shadow-lg dark:bg-sky-700'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700',
              ]}
            >
              {category}
              <span
                class:list={[
                  'ml-2 rounded-full px-2 py-0.5 text-xs font-semibold',
                  isActive
                    ? 'bg-white text-sky-700'
                    : 'bg-gray-200 text-gray-600 dark:bg-gray-700 dark:text-gray-400',
                ]}
              >
                {skills[category].length}
              </span>
            </button>
          );
        })
      }
    </div>

    {
      categories.map((category) => {
        const isActive = category === firstCategory;
        const slug = slugify(category);
        return (
          <div
            id={`panel-${slug}`}
            role="tabpanel"
            aria-labelledby={`tab-${slug}`}
            data-category={category}
            class:list={['skills-panel', isActive ? '' : 'hidden']}
          >
            <div class="grid grid-cols-3 gap-6 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
              {skills[category].map((skill) => (
                <div class="group flex flex-col items-center">
                  <div class="mb-3 flex h-16 w-16 items-center justify-center rounded-2xl border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800">
                    <Icon name={getSkillIcon(skill)} class="size-8" />
                  </div>
                  <span class="text-center text-sm font-medium text-gray-700 dark:text-gray-300">
                    {skill}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      })
    }

    <div class="mt-20 text-center">
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Always learning and exploring new technologies to stay current with industry trends.
      </p>
    </div>
  </div>
</section>

<script>
  const tablist = document.getElementById('skills-tablist');
  if (tablist) {
    const tabs = tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]');
    const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.category;

        tabs.forEach((t) => {
          const isSelected = t.dataset.category === target;
          t.setAttribute('aria-selected', isSelected ? 'true' : 'false');

          if (isSelected) {
            t.classList.add('bg-sky-700', 'text-white', 'shadow-lg', 'dark:bg-sky-700');
            t.classList.remove(
              'bg-gray-100',
              'text-gray-700',
              'hover:bg-gray-200',
              'dark:bg-gray-800',
              'dark:text-gray-300',
              'dark:hover:bg-gray-700',
            );

            const badge = t.querySelector('span');
            if (badge) {
              badge.classList.add('bg-white', 'text-sky-700');
              badge.classList.remove(
                'bg-gray-200',
                'text-gray-600',
                'dark:bg-gray-700',
                'dark:text-gray-400',
              );
            }
          } else {
            t.classList.remove('bg-sky-700', 'text-white', 'shadow-lg', 'dark:bg-sky-700');
            t.classList.add(
              'bg-gray-100',
              'text-gray-700',
              'hover:bg-gray-200',
              'dark:bg-gray-800',
              'dark:text-gray-300',
              'dark:hover:bg-gray-700',
            );
            const badge = t.querySelector('span');
            if (badge) {
              badge.classList.remove('bg-white', 'text-sky-700');
              badge.classList.add(
                'bg-gray-200',
                'text-gray-600',
                'dark:bg-gray-700',
                'dark:text-gray-400',
              );
            }
          }
        });

        panels.forEach((panel) => {
          if (panel.dataset.category === target) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });
  }
</script>
