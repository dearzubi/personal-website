---
import { Icon } from 'astro-icon/components';
import { experience } from '@/data/site';
import { getSkillIcon } from '@/lib/getSkillIcon';
import ExperienceLines from './ExperienceLines.astro';
---

<section id="experience" class="py-16">
  <div class="section-container">
  <h2 class="section-title">Work Experience</h2>
  <p class="section-subtitle">
    My professional journey that shaped my expertise in software development and technology.
  </p>

  <div class="mt-12 space-y-12">
    {experience.map((role) => (
      <article class="rounded-lg border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-800/90">
        <div class="mb-6 flex flex-col justify-between gap-4 md:flex-row md:items-start">
          <div>
            <h3 class="text-xl font-bold">{role.role}</h3>
            {role.company && (
              <p class="mt-1 font-semibold text-sky-500">{role.company}</p>
            )}
            {role.location && (
              <div class="mt-1 flex items-center gap-1 text-sm text-muted-foreground">
                <Icon name="lucide:map-pin" class="size-4 text-sky-500" />
                {role.location}
              </div>
            )}
          </div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Icon name="lucide:calendar-days" class="size-4 text-sky-500" />
            <span class="font-medium">{role.start} – {role.end}</span>
          </div>
        </div>

        {role.lines && role.lines.length > 0 && (
          <div class="mb-6">
            <strong class="font-semibold">Key Achievements:</strong>
            <ExperienceLines lines={role.lines} />
          </div>
        )}

        {role.note && (
          <p class="mb-6 italic text-muted-foreground">{role.note}</p>
        )}

        {role.technologies && role.technologies.length > 0 && (
          <div>
            <h4 class="mb-3 font-semibold">Key Technologies:</h4>
            <div class="flex flex-wrap gap-2">
              {role.technologies.map((t) => (
                <span class="tech-tag inline-flex items-center gap-1.5">
                  <Icon name={getSkillIcon(t)} class="size-3.5" />
                  {t}
                </span>
              ))}
            </div>
          </div>
        )}
      </article>
    ))}
  </div>
  </div>
</section>
