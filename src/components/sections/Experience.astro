---
import { Icon } from 'astro-icon/components';
import type { ExperienceLine } from '@/data/site';
import { experience } from '@/data/site';

function renderLines(lines: ExperienceLine[], depth = 0): string {
  return lines
    .map((line) => {
      const indent = depth > 0 ? `ml-${depth * 4}` : '';
      let li = '';
      if (line.type === 'heading') {
        li = `<li class="${indent} mt-4 font-semibold">${line.value}</li>`;
      } else if (line.type === 'bullet') {
        li = `<li class="${indent} flex items-start gap-2"><span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sky-500"></span><span>${line.value}</span></li>`;
      } else {
        li = `<li class="${indent}">${line.value}</li>`;
      }
      const sub =
        line.subLines && line.subLines.length > 0
          ? `<ul class="mt-1 ml-6 space-y-1">${renderLines(line.subLines, depth + 1)}</ul>`
          : '';
      return li + sub;
    })
    .join('');
}
---

<section id="experience" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-bold md:text-4xl">Work Experience</h2>
  <p class="mt-4 text-lg text-(--color-muted-foreground)">
    My professional journey that shaped my expertise in software development and technology.
  </p>

  <div class="mt-12 space-y-12">
    {experience.map((role) => (
      <article class="rounded-2xl border border-(--color-border) bg-(--color-card) p-8 shadow-sm">
        <div class="mb-6 flex flex-col justify-between gap-4 md:flex-row md:items-start">
          <div>
            <h3 class="text-xl font-bold">{role.role}</h3>
            {role.company && (
              <p class="mt-1 font-semibold text-sky-500">{role.company}</p>
            )}
            {role.location && (
              <div class="mt-1 flex items-center gap-1 text-sm text-(--color-muted-foreground)">
                <Icon name="lucide:map-pin" class="size-4 text-sky-500" />
                {role.location}
              </div>
            )}
          </div>
          <div class="flex items-center gap-2 text-sm text-(--color-muted-foreground)">
            <Icon name="lucide:calendar-days" class="size-4 text-sky-500" />
            <span class="font-medium">{role.start} – {role.end}</span>
          </div>
        </div>

        {role.lines && role.lines.length > 0 && (
          <div class="mb-6">
            <strong class="font-semibold">Key Achievements:</strong>
            <ul class="mt-2 space-y-2" set:html={renderLines(role.lines)} />
          </div>
        )}

        {role.note && (
          <p class="mb-6 italic text-(--color-muted-foreground)">{role.note}</p>
        )}

        {role.technologies && role.technologies.length > 0 && (
          <div>
            <h4 class="mb-3 font-semibold">Key Technologies:</h4>
            <div class="flex flex-wrap gap-2">
              {role.technologies.map((t) => (
                <span class="inline-flex rounded-full border border-(--color-border) px-3 py-1 text-xs">{t}</span>
              ))}
            </div>
          </div>
        )}
      </article>
    ))}
  </div>
</section>
