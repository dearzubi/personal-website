---
import { Icon } from 'astro-icon/components';
import { profile } from '@/data/site';
---

<section id="hero" class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
    <div class="order-2 lg:order-1">
      <h1 class="mb-6 flex flex-col text-5xl font-bold leading-tight lg:text-6xl xl:text-7xl">
        <span>Hi, I'm </span>
        <span class="bg-gradient-to-r from-sky-400 via-sky-500 to-sky-600 bg-clip-text text-transparent">
          {profile.name}
        </span>
      </h1>

      <h2 class="mb-6 text-xl font-medium text-(--color-muted-foreground) lg:text-2xl">
        {profile.title}
      </h2>

      <p class="mb-8 max-w-lg text-lg leading-relaxed text-(--color-muted-foreground)">
        {profile.blurb}
      </p>

      <div class="mb-10">
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-(--color-muted-foreground)">
          Core Skills
        </h3>
        <div class="flex flex-wrap gap-3">
          {profile.coreTechnologies.map((tech) => (
            <span class="inline-flex rounded-full border border-(--color-border) bg-(--color-muted) px-3 py-1 text-sm">
              {tech}
            </span>
          ))}
        </div>
      </div>

      <div class="mb-8">
        <div class="flex flex-wrap items-center gap-4">
          <a
            href={profile.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-medium transition-colors hover:text-sky-500"
            aria-label="GitHub (@dearzubi)"
          >
            <Icon name="lucide:github" class="size-5" />
            @dearzubi
          </a>

          <a
            href={profile.links.githubAlt}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-medium transition-colors hover:text-sky-500"
            aria-label="GitHub (@coolpengwing)"
          >
            <Icon name="lucide:github" class="size-5" />
            @coolpengwing
          </a>

          <a
            href={profile.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-medium transition-colors hover:text-sky-500"
            aria-label="LinkedIn"
          >
            <Icon name="lucide:linkedin" class="size-5" />
            zubair-khalid
          </a>
        </div>
      </div>

      <div class="mb-8 flex flex-col gap-4 sm:flex-row">
        <a
          href="/Zubair_Khalid_CV.pdf"
          download="Zubair_Khalid_CV.pdf"
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-(--color-primary) px-6 py-3 text-sm font-semibold text-(--color-primary-foreground) shadow-lg transition-colors hover:opacity-90"
        >
          <Icon name="lucide:download" class="size-4" />
          Download CV
        </a>

        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-xl border border-(--color-border) px-6 py-3 text-sm font-semibold transition-colors hover:border-sky-400 hover:text-sky-500"
        >
          Get In Touch
        </a>
      </div>

      <p class="mt-4 italic text-(--color-muted-foreground)">
        Legally authorised to work in the UK, no sponsorship required. Available for remote, hybrid, or Manchester-based roles.
      </p>
    </div>

    <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
      <div class="relative h-80 w-80 lg:h-96 lg:w-96">
        <div class="h-full w-full overflow-hidden rounded-full bg-gradient-to-br from-sky-200 to-sky-300 p-2 shadow-2xl">
          <div class="h-full w-full overflow-hidden rounded-full bg-white">
            <img
              src="/dp.png"
              alt={profile.name}
              class="h-full w-full object-cover object-center"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
