---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import dpImage from '@/assets/dp.jpeg';
import { profile } from '@/data/site';
import { getSkillIcon } from '@/lib/getSkillIcon';
---

<section
  id="home"
  class="relative flex items-center justify-center overflow-hidden pt-8"
>
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.08] dark:opacity-[0.12]">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke="currentColor"
              stroke-width="0.5"
              class="text-gray-600 dark:text-gray-400"
            ></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div class="order-2 lg:order-1">
        <h1 class="mb-6 flex flex-col text-5xl font-bold leading-tight lg:text-6xl xl:text-7xl">
          <span class="text-gray-900 dark:text-gray-100">Hi, I'm </span>
          <span class="gradient-text">
            {profile.name}
          </span>
        </h1>

        <h2 class="mb-6 text-xl font-medium text-gray-700 dark:text-gray-300 lg:text-2xl">
          {profile.title}
        </h2>

        <p class="mb-8 max-w-lg text-lg leading-relaxed text-gray-600 dark:text-gray-400">
          {profile.blurb}
        </p>

        <div class="mb-10">
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400"
          >
            Core Skills
          </h3>
          <div class="flex flex-wrap gap-3">
            {
              profile.coreTechnologies.map((skill) => (
                <span class="skill-chip gap-2">
                  <Icon name={getSkillIcon(skill)} class="size-4" />
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

        <div class="mb-8">
          <div class="flex flex-wrap items-center gap-4">
            <a
              href={profile.links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center space-x-2 rounded-lg px-2 py-1 text-gray-600 transition-all duration-300 hover:scale-105 hover:text-sky-600 dark:text-gray-300 dark:hover:text-sky-400"
              aria-label="GitHub (@dearzubi)"
            >
              <Icon name="lucide:github" class="h-5 w-5" />
              <span class="text-sm font-medium">@dearzubi</span>
            </a>

            <a
              href={profile.links.githubAlt}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center space-x-2 rounded-lg px-2 py-1 text-gray-600 transition-all duration-300 hover:scale-105 hover:text-sky-600 dark:text-gray-300 dark:hover:text-sky-400"
              aria-label="GitHub (@coolpengwing)"
            >
              <Icon name="lucide:github" class="h-5 w-5" />
              <span class="text-sm font-medium">@coolpengwing</span>
            </a>

            <a
              href={profile.links.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center space-x-2 rounded-lg px-2 py-1 text-gray-600 transition-all duration-300 hover:scale-105 hover:text-sky-600 dark:text-gray-300 dark:hover:text-sky-400"
              aria-label="LinkedIn"
            >
              <Icon name="lucide:linkedin" class="h-5 w-5" />
              <span class="text-sm font-medium">zubair-khalid</span>
            </a>
          </div>
        </div>

        <div class="mb-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/Zubair_Khalid_CV.pdf"
            download="Zubair_Khalid_CV.pdf"
            class="btn-primary gap-2"
          >
            <Icon name="lucide:download" class="h-4 w-4" />
            Download CV
          </a>

          <a href="#contact" class="btn-secondary">
            Get In Touch
          </a>
        </div>

        <p class="mt-4 italic text-gray-500 dark:text-gray-400">
          Legally authorised to work in the UK, no sponsorship required. Available for remote,
          hybrid, or Manchester-based roles.
        </p>
      </div>

      <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
        <div class="relative">
          <div class="relative h-80 w-80 lg:h-96 lg:w-96">
            <div
              class="hero-float h-full w-full overflow-hidden rounded-full bg-gradient-to-br from-sky-200 to-sky-300 p-2 shadow-2xl"
            >
              <div class="h-full w-full overflow-hidden rounded-full bg-white">
                <Image
                  src={dpImage}
                  alt={profile.name}
                  widths={[320, 384, 768]}
                  sizes="(min-width: 1024px) 24rem, 20rem"
                  loading="eager"
                  fetchpriority="high"
                  class="h-full w-full object-cover object-center"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
