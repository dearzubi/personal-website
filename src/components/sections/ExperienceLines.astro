---
import type { ExperienceLine } from '@/data/site';

type Props = { lines: ExperienceLine[]; nested?: boolean };
const { lines, nested = false } = Astro.props;
const listClass = nested ? 'mt-1 ml-6 space-y-1' : 'mt-2 space-y-2';
---

<ul class={listClass}>
  {lines.map((line) => (
    <li class:list={[line.type === 'heading' && 'mt-4']}>
      {line.type === 'heading' && <span class="font-semibold">{line.value}</span>}
      {line.type === 'bullet' && (
        <div class="flex items-start gap-2">
          <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sky-500" />
          <span>{line.value}</span>
        </div>
      )}
      {line.type === 'text' && line.value}
      {line.subLines && line.subLines.length > 0 && (
        <Astro.self lines={line.subLines} nested />
      )}
    </li>
  ))}
</ul>
