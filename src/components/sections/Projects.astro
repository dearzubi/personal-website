---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { projects } from '@/data/site';
import { getSkillIcon } from '@/lib/getSkillIcon';

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  '@/assets/projects/**/*.{png,jpg,jpeg,webp,avif}',
  { eager: true },
);

const imageLookup = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(projectImages)) {
  const key = path.replace(/^.*\/assets\/projects\//, '/projects/');
  imageLookup.set(key, mod.default);
}

function resolveImage(src: string | undefined): ImageMetadata | undefined {
  if (!src) return undefined;
  return imageLookup.get(src);
}

type LinkKind = 'github' | 'gitlab' | 'website';

function classifyLink(url: string): LinkKind {
  try {
    const host = new URL(url).hostname.toLowerCase();
    if (host === 'github.com' || host.endsWith('.github.com')) return 'github';
    if (host === 'gitlab.com' || host.endsWith('.gitlab.com')) return 'gitlab';
  } catch {
    /* ignore parse failure, fall through */
  }
  return 'website';
}

const linkMeta: Record<LinkKind, { icon: string; label: string }> = {
  github: { icon: 'lucide:github', label: 'Visit Code' },
  gitlab: { icon: 'simple-icons:gitlab', label: 'Visit Code' },
  website: { icon: 'lucide:globe', label: 'Visit Website' },
};
---

<section id="projects" class="py-16">
  <div class="section-container">
    <h2 class="section-title">Projects</h2>
    <p class="section-subtitle">
      A selection of projects that showcase my skills in full-stack development and modern web
      technologies.
    </p>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => {
          const projectImage = resolveImage(project.image);
          return (
            <div class="group flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-800/90">
              <div class="mb-6 overflow-hidden rounded-md">
                {projectImage ? (
                  <Image
                    src={projectImage}
                    alt={project.name}
                    widths={[320, 480, 768]}
                    sizes="(min-width: 1024px) 20rem, (min-width: 768px) 33vw, 100vw"
                    class="h-48 w-full object-cover"
                  />
                ) : (
                  <div class="flex h-48 items-center justify-center rounded-md bg-gradient-to-br from-sky-50 to-sky-100">
                    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white">
                      <span class="text-2xl font-bold text-sky-600">
                        {project.name.charAt(0).toUpperCase()}
                      </span>
                    </div>
                  </div>
                )}
              </div>

              <div class="flex flex-1 flex-col">
                <h3 class="mb-3 text-xl font-bold">{project.name}</h3>

                <p class="mb-4 text-muted-foreground">{project.description}</p>

                <div class="mb-6 flex flex-wrap gap-2">
                  {project.stack.slice(0, 10).map((tech) => (
                    <span class="tech-tag inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs">
                      <Icon name={getSkillIcon(tech)} class="size-3" />
                      {tech}
                    </span>
                  ))}
                  {project.stack.length > 10 && (
                    <span class="tech-tag inline-flex rounded-lg px-2 py-1 text-xs">
                      +{project.stack.length - 10}
                    </span>
                  )}
                </div>

                {project.links && project.links.length > 0 && (
                  <div class="mt-auto flex flex-wrap gap-3">
                    {project.links.map((url) => {
                      const kind = classifyLink(url);
                      const { icon, label } = linkMeta[kind];
                      return (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn-secondary gap-2 px-4 py-2"
                        >
                          <Icon name={icon} class="size-4" />
                          {label}
                          <Icon name="lucide:external-link" class="size-3" />
                        </a>
                      );
                    })}
                  </div>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
