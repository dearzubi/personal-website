---
import { Icon } from 'astro-icon/components';
import { projects } from '@/data/site';

const featuredProjects = projects.filter((p) => p.isFeatured);
const otherProjects = projects.filter((p) => !p.isFeatured);
---

<section id="projects" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-bold md:text-4xl">Featured Projects</h2>
  <p class="mt-4 text-lg text-(--color-muted-foreground)">
    A selection of projects that showcase my skills in full-stack development and modern web technologies.
  </p>

  <!-- Featured projects: alternating layout -->
  <div class="mt-12 space-y-24">
    {featuredProjects.map((project, index) => (
      <div class={`grid grid-cols-1 items-center gap-16 lg:grid-cols-2`}>
        <!-- Image column -->
        <div class={index % 2 === 1 ? 'lg:order-2' : 'lg:order-1'}>
          <div class="overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-card) shadow-sm">
            {project.image ? (
              <img
                src={project.image}
                alt={project.name}
                class="h-80 w-full object-cover rounded-2xl"
              />
            ) : (
              <div class="flex h-80 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-50 to-sky-100">
                <div class="flex h-24 w-24 items-center justify-center rounded-full bg-white shadow-lg">
                  <span class="text-3xl font-bold text-sky-600">
                    {project.name.charAt(0).toUpperCase()}
                  </span>
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- Content column -->
        <div class={index % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}>
          {project.category && (
            <span class="mb-4 inline-block rounded-full bg-sky-100 px-4 py-1 text-sm font-medium text-sky-700">
              {project.category}
            </span>
          )}

          <h3 class="mb-4 text-3xl font-bold md:text-4xl">{project.name}</h3>

          <p class="mb-6 text-lg leading-relaxed text-(--color-muted-foreground)">
            {project.description}
          </p>

          <div class="mb-8 flex flex-wrap gap-3">
            {project.stack.slice(0, 10).map((tech) => (
              <span class="inline-flex rounded-lg border border-(--color-border) bg-(--color-muted) px-3 py-2 text-sm">
                {tech}
              </span>
            ))}
            {project.stack.length > 10 && (
              <span class="inline-flex rounded-lg border border-(--color-border) bg-(--color-muted) px-3 py-2 text-sm text-(--color-muted-foreground)">
                +{project.stack.length - 10} more
              </span>
            )}
          </div>

          <div class="flex flex-wrap gap-4">
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl bg-(--color-primary) px-6 py-3 text-sm font-semibold text-(--color-primary-foreground) transition-opacity hover:opacity-90"
              >
                Visit Website
                <Icon name="lucide:external-link" class="size-3" />
              </a>
            )}

            {typeof project.githubLink === 'string' && (
              <a
                href={project.githubLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl border border-(--color-border) px-6 py-3 text-sm font-semibold transition-colors hover:border-sky-400"
              >
                <Icon name="lucide:github" class="size-4" />
                View Code
                <Icon name="lucide:external-link" class="size-3" />
              </a>
            )}

            {Array.isArray(project.githubLink) && project.githubLink.map((repo) => (
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl border border-(--color-border) px-6 py-3 text-sm font-semibold transition-colors hover:border-sky-400"
              >
                <Icon name="lucide:github" class="size-4" />
                {repo.label}
                <Icon name="lucide:external-link" class="size-3" />
              </a>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Other projects: grid -->
  {otherProjects.length > 0 && (
    <div class="mt-24">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl">More Projects</h2>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {otherProjects.map((project) => (
          <div class="group rounded-2xl border border-(--color-border) bg-(--color-card) p-8 shadow-sm transition-shadow hover:shadow-lg">
            <div class="mb-6 overflow-hidden rounded-2xl">
              {project.image ? (
                <img
                  src={project.image}
                  alt={project.name}
                  class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              ) : (
                <div class="flex h-48 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-50 to-sky-100">
                  <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white shadow-lg">
                    <span class="text-2xl font-bold text-sky-600">
                      {project.name.charAt(0).toUpperCase()}
                    </span>
                  </div>
                </div>
              )}
            </div>

            <div class="flex flex-col">
              {project.category && (
                <span class="mb-3 inline-block w-fit rounded-full bg-sky-100 px-3 py-1 text-xs font-medium text-sky-700">
                  {project.category}
                </span>
              )}

              <h3 class="mb-3 text-xl font-bold transition-colors group-hover:text-sky-500">
                {project.name}
              </h3>

              <p class="mb-4 text-(--color-muted-foreground)">{project.description}</p>

              <div class="mb-6 flex flex-wrap gap-2">
                {project.stack.slice(0, 10).map((tech) => (
                  <span class="inline-flex rounded-lg border border-(--color-border) bg-(--color-muted) px-2 py-1 text-xs">
                    {tech}
                  </span>
                ))}
                {project.stack.length > 10 && (
                  <span class="inline-flex rounded-lg border border-(--color-border) bg-(--color-muted) px-2 py-1 text-xs text-(--color-muted-foreground)">
                    +{project.stack.length - 10}
                  </span>
                )}
              </div>

              <div class="flex flex-wrap gap-3">
                {project.link && (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex flex-1 items-center justify-center gap-1 rounded-xl bg-(--color-primary) px-4 py-2 text-sm font-semibold text-(--color-primary-foreground) transition-opacity hover:opacity-90"
                  >
                    Visit Website
                    <Icon name="lucide:external-link" class="size-3" />
                  </a>
                )}

                {typeof project.githubLink === 'string' && (
                  <a
                    href={project.githubLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-xl border border-(--color-border) px-4 py-2 text-sm font-semibold transition-colors hover:border-sky-400"
                  >
                    <Icon name="lucide:github" class="size-4" />
                    View Code
                  </a>
                )}

                {Array.isArray(project.githubLink) && project.githubLink.map((repo) => (
                  <a
                    href={repo.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-xl border border-(--color-border) px-4 py-2 text-sm font-semibold transition-colors hover:border-sky-400"
                  >
                    <Icon name="lucide:github" class="size-4" />
                    {repo.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</section>
