---
import { Icon } from 'astro-icon/components';
import { education } from '@/data/site';
---

<section id="education" class="py-16">
  <div class="section-container">
  <h2 class="section-title">Education</h2>
  <p class="section-subtitle">
    My academic background and qualifications.
  </p>

  <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
    {education.map((edu) => (
      <article class="rounded-lg border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-800/90">
        <div class="mb-4 flex items-start gap-4">
          <div class="rounded-full bg-sky-50 p-3 dark:bg-sky-900/30">
            <Icon name="lucide:graduation-cap" class="size-6 text-sky-500" />
          </div>
          <div>
            <h3 class="text-xl font-semibold">{edu.degree}</h3>
            <p class="mt-1 text-lg text-muted-foreground">{edu.school}</p>
          </div>
        </div>

        <div class="flex items-center gap-2 text-muted-foreground">
          <Icon name="lucide:calendar" class="size-4 text-sky-500" />
          {edu.dates}
        </div>
      </article>
    ))}
  </div>
  </div>
</section>
