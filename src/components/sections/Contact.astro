---
import { Icon } from 'astro-icon/components';
import { profile } from '@/data/site';
---

<section id="contact" class="py-16">
  <div class="section-container">
  <h2 class="section-title">Get In Touch</h2>
  <p class="section-subtitle">
    Have a question or want to work together? Feel free to reach out!
  </p>

  <div class="mt-8 flex flex-col gap-4">
    <div class="flex w-full flex-wrap justify-between gap-4">
      <!-- Email -->
      <div class="flex items-center gap-4">
        <div class="rounded-full bg-sky-50 p-3 dark:bg-sky-900/30">
          <Icon name="lucide:mail" class="size-5 text-sky-500" />
        </div>
        <div>
          <p class="font-medium">Email</p>
          <a
            href={`mailto:${profile.email}`}
            class="text-muted-foreground transition-colors hover:text-sky-500"
          >
            {profile.email}
          </a>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="rounded-full bg-sky-50 p-3 dark:bg-sky-900/30">
          <Icon name="lucide:map-pin" class="size-5 text-sky-500" />
        </div>
        <div>
          <p class="font-medium">Location</p>
          <p class="text-muted-foreground">{profile.location}</p>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="rounded-full bg-sky-50 p-3 dark:bg-sky-900/30">
          <Icon name="lucide:file-check" class="size-5 text-sky-500" />
        </div>
        <div>
          <p class="font-medium">Right to Work</p>
          <p class="text-muted-foreground">{profile.rightToWork}</p>
        </div>
      </div>
    </div>

    <div class="flex w-full justify-center">
      <p class="mt-4 italic text-muted-foreground">
        Legally entitled to work in the UK, no sponsorship required.
      </p>
    </div>
  </div>
  </div>
</section>
