---
import { getCollection } from 'astro:content';
import BlogIndexLayout from '@/layouts/BlogIndexLayout.astro';
import { getPostsBySeries } from '@/lib/collections';

export async function getStaticPaths() {
  const seriesList = await getCollection('series');
  return Promise.all(
    seriesList.map(async (s) => ({
      params: { series: s.id },
      props: { series: s, posts: await getPostsBySeries(s.id) },
    })),
  );
}

const { series, posts } = Astro.props;
---

<BlogIndexLayout title={series.data.title} description={series.data.description}>
  <h1 class="text-4xl font-bold">{series.data.title}</h1>
  <p class="mt-4 text-lg text-muted-foreground">{series.data.description}</p>
  <ol class="mt-8 space-y-4">
    {posts.map((post, i) => (
      <li class="flex gap-4">
        <span class="text-muted-foreground">{(post.data.seriesOrder ?? i) + 1}.</span>
        <a href={`/blog/${post.id}`} class="font-semibold hover:text-primary">{post.data.title}</a>
      </li>
    ))}
  </ol>
</BlogIndexLayout>
