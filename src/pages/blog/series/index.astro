---
import { getCollection } from 'astro:content';
import BlogIndexLayout from '@/layouts/BlogIndexLayout.astro';

const seriesList = await getCollection('series');
---

<BlogIndexLayout title="Series">
  <h1 class="text-4xl font-bold">Series</h1>
  <ul class="mt-8 space-y-6">
    {seriesList.map((s) => (
      <li>
        <a href={`/blog/series/${s.id}`} class="group block">
          <h2 class="text-xl font-semibold group-hover:text-(--color-primary)">{s.data.title}</h2>
          <p class="text-(--color-muted-foreground)">{s.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BlogIndexLayout>
