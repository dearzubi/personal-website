---
import BlogIndexLayout from '@/layouts/BlogIndexLayout.astro';
import { getBlogPosts } from '@/lib/collections';

const posts = await getBlogPosts();
const tally = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) tally.set(tag, (tally.get(tag) ?? 0) + 1);
}
const counts = [...tally.entries()].sort(([a], [b]) => a.localeCompare(b));
---

<BlogIndexLayout title="Tags">
  <h1 class="text-4xl font-bold">Tags</h1>
  <ul class="mt-8 flex flex-wrap gap-3">
    {counts.map(([tag, count]) => (
      <li>
        <a href={`/blog/tags/${encodeURIComponent(tag)}`} class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2">
          <span>#{tag}</span>
          <span class="text-sm text-muted-foreground">{count}</span>
        </a>
      </li>
    ))}
  </ul>
</BlogIndexLayout>
